# Copy these into Vercel → Project → Settings → Environment Variables.
# Do NOT commit real values to git.

# --- PayHero ---
PAYHERO_AUTH=BasicSlJvSEdUOVFMUmg2RjFhRktlTVY6ZXhkMUFMR3VpUmRucjhVeFRtVEl3Tk9RdnEzUHdjemUwamNCdGwyVQ==
PAYHERO_CHANNEL_ID=5580
# Use your deployed URL once you know it, ending in /api/callback:
PAYHERO_CALLBACK_URL=https://your-app.vercel.app/api/callback

# --- Payment status store (free Upstash Redis, or Vercel KV) ---
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_WITH_YOUR_TOKEN
# If you use Vercel KV instead, it sets KV_REST_API_URL / KV_REST_API_TOKEN
# automatically and the app will pick those up too.
